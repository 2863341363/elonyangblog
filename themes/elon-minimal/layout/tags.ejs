<% const tags = site.tags.sort('name').toArray(); %>

<section class="page-title">
  <p class="eyebrow">Keywords</p>
  <h1>标签</h1>
  <p>用更细的关键词找到相关内容。</p>
</section>

<section class="paper">
  <div class="tag-cloud">
    <% if (tags.length) { %>
      <% tags.forEach(function(tag) { %>
        <a href="<%- url_for(tag.path) %>"><%= tag.name %> <span><%= tag.length %></span></a>
      <% }) %>
    <% } else { %>
      <% ['知识分享', '项目复盘', '资源共享', '学习路线', '工具效率'].forEach(function(name) { %>
        <span class="tag-placeholder"><%= name %></span>
      <% }) %>
    <% } %>
  </div>
</section>
